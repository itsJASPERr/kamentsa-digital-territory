---
import { t, type Language } from '../i18n/utils';
import Navigation from './Navigation.astro';
import DonorModal from './DonorModal.astro';
import Hero from './Hero.astro';
import Vision from './Vision.astro';
import FamilyCircle from './FamilyCircle.astro';
import Blueprint from './Blueprint.astro';
import LivingLoom from './LivingLoom.astro';
import Altar from './Altar.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import '../styles/global.css';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const pageTitle = t(lang, 'hero.title');
const langCode = t(lang, 'language.code');
const currentPath = Astro.url.pathname;
---

<html lang={langCode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Kamëntsá — {pageTitle}</title>
  </head>
  <body>
      
    <Header lang={lang} currentPath={currentPath} />

    <!-- <Navigation lang={lang} currentPath={currentPath} /> -->

    <Hero lang={lang} />

    <Vision lang={lang} />

    <FamilyCircle lang={lang} />

    <Blueprint lang={lang} />

    <LivingLoom lang={lang} />

    <Altar lang={lang} />

    <Footer lang={lang} />

    <DonorModal lang={lang} />

  </body>
</html>
