---
// This component requires the lang prop to handle translations
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#0c0c0c]">
  <!-- Background Image with atmospheric overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/putumayo-valley.jpg" 
      alt="The misty winds of the Putumayo Valley" 
      class="w-full h-full object-cover opacity-40 filter saturate-50"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0c0c0c]/80 via-transparent to-[#0c0c0c]"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-[5%] text-center mt-20">
    <span class="font-title text-sm md:text-base text-padre-sol tracking-[0.3em] uppercase block mb-6 animate-fade-in">
      {t(lang, 'hero.seed')}
    </span>
    
    <h1 class="font-title text-5xl md:text-7xl lg:text-8xl text-fibra-natural uppercase tracking-widest mb-4 drop-shadow-lg">
      {t(lang, 'hero.title')}
    </h1>
    
    <h2 class="font-title text-xl md:text-2xl text-agua-pura tracking-widest uppercase mb-10">
      {t(lang, 'hero.subtitle')}
    </h2>

    <p class="font-body text-lg md:text-2xl text-fibra-natural/90 max-w-3xl mx-auto leading-relaxed mb-12">
      {t(lang, 'hero.description')}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="#vision" class="w-full sm:w-auto px-8 py-4 border border-fibra-natural/30 text-fibra-natural font-title text-sm tracking-widest uppercase hover:bg-fibra-natural hover:text-[#0c0c0c] transition-all duration-300 text-center">
        {t(lang, 'hero.supportBtn')}
      </a>
      <a href="#video" class="w-full sm:w-auto px-8 py-4 bg-sangre-viva text-fibra-natural font-title text-sm tracking-widest uppercase hover:bg-red-700 transition-all duration-300 text-center">
        {t(lang, 'hero.videoBtn')}
      </a>
    </div>
  </div>
</section>
