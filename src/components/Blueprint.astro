---
// This component requires the lang prop to handle translations
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="blueprint" class="bg-[#111] py-32 px-[5%] md:px-[10%] relative faja-divider border-t border-fibra-natural/10">
  <div class="max-w-6xl mx-auto space-y-16">
    
    <!-- HEADER -->
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <span class="font-title text-sm text-padre-sol tracking-widest uppercase block animate-pulse">
        {t(lang, 'blueprint.currentGoal')}
      </span>
      <h2 class="font-title text-4xl md:text-5xl text-fibra-natural uppercase tracking-wide">
        {t(lang, 'blueprint.title')}
      </h2>
      <p class="font-body text-fibra-natural/60 text-lg">
        {t(lang, 'blueprint.fundingMessage')}
      </p>
    </div>

    <!-- THE STAGES LAYOUT -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch pt-8">
      
      <!-- STAGE 1: ACTIVE -->
      <div class="border-2 border-padre-sol bg-[#111] p-8 flex flex-col justify-between relative group">
        <div class="absolute top-0 right-0 bg-padre-sol text-[#0c0c0c] font-title text-xs uppercase tracking-widest px-4 py-1 font-bold">
          Active Phase
        </div>
        <div class="space-y-6">
          <div class="space-y-2">
            <span class="font-title text-xs text-padre-sol uppercase tracking-widest block">Phase 01</span>
            <h3 class="font-title text-2xl text-fibra-natural uppercase tracking-wide">{t(lang, 'blueprint.stage1Title')}</h3>
          </div>
          <ul class="space-y-4 font-body text-fibra-natural/80 text-base leading-relaxed [&>li]:relative [&>li]:before:content-['▸'] [&>li]:before:absolute [&>li]:before:left-[-1em] [&>li]:before:select-none [&>li]:before:text-padre-sol">
            <li class="pt-2">
              {t(lang, 'blueprint.stage1Item1')}
            </li>
            <li class="pt-4">{t(lang, 'blueprint.stage1Item2')}</li>
          </ul>
        </div>
      </div>

      <!-- STAGE 2: FUTURE -->
      <div class="border border-fibra-natural/10 bg-[#111]/40 p-8 flex flex-col justify-between relative opacity-80 hover:opacity-100 transition-opacity duration-300">
        <div class="space-y-6">
          <div class="space-y-2">
            <span class="font-title text-xs text-sangre-viva uppercase tracking-widest block">Phase 02</span>
            <h3 class="font-title text-2xl text-fibra-natural uppercase tracking-wide">{t(lang, 'blueprint.stage2Title')}</h3>
          </div>
          <ul class="space-y-4 font-body text-fibra-natural/70 text-base leading-relaxed [&>li]:relative [&>li]:before:content-['▸'] [&>li]:before:absolute [&>li]:before:left-[-1em] [&>li]:before:select-none [&>li]:before:text-sangre-viva">
            <li class="pt-2">{t(lang, 'blueprint.stage2Item1')}</li>
            <li class="pt-4">{t(lang, 'blueprint.stage2Item2')}</li>
            <li class="pt-4">{t(lang, 'blueprint.stage2Item3')}</li>
            <li class="pt-4">{t(lang, 'blueprint.stage2Item4')}</li>
          </ul>
        </div>
      </div>

      <!-- STAGE 3: FUTURE -->
      <div class="border border-fibra-natural/10 bg-[#111]/40 p-8 flex flex-col justify-between relative opacity-80 hover:opacity-100 transition-opacity duration-300">
        <div class="space-y-6">
          <div class="space-y-2">
            <span class="font-title text-xs text-agua-pura uppercase tracking-widest block">Phase 03</span>
            <h3 class="font-title text-2xl text-fibra-natural uppercase tracking-wide">{t(lang, 'blueprint.stage3Title')}</h3>
          </div>
          <ul class="space-y-4 font-body text-fibra-natural/70 text-base leading-relaxed [&>li]:relative [&>li]:before:content-['▸'] [&>li]:before:absolute [&>li]:before:left-[-1em] [&>li]:before:select-none [&>li]:before:text-agua-pura">
            <li class="pt-2">{t(lang, 'blueprint.stage3Item1')}</li>
            <li class="pt-4">{t(lang, 'blueprint.stage3Item2')}</li>
          </ul>
        </div>
      </div>

    </div>

  </div>
</section>
