---
// Section 4: The Blueprint of Kabunga
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="blueprint" class="bg-[#111] py-24 px-[5%] md:px-[10%] relative faja-divider">
  <div class="max-w-7xl mx-auto">
    
    <div class="text-center mb-20">
      <h2 class="font-title text-4xl sm:text-5xl md:text-6xl text-padre-sol uppercase tracking-wide drop-shadow-[2px_2px_0_#f6007b] mb-10">
        The Blueprint of Kabunga
      </h2>
      
      <div class="max-w-3xl mx-auto bg-tierra-madre border-2 border-sombra-selva p-6 md:p-8 shadow-[8px_8px_0_#0c0c0c]">
        <p class="text-xl md:text-2xl font-title text-agua-pura uppercase tracking-wider mb-4">
          Current Goal: Funding Stage 1 (The Tambo)
        </p>
        <div class="w-full bg-[#222] border-2 border-fibra-natural p-[3px] overflow-hidden">
          <div class="serpiente-progress h-8 w-[35%] flex items-center justify-center font-bold text-fibra-natural drop-shadow-[1px_1px_2px_#000]">
            35%
          </div>
        </div>
        <p class="text-fibra-natural/60 text-sm mt-4 font-body uppercase tracking-widest">
          Every contribution builds the foundation
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-10 md:gap-8 items-stretch mt-12">
      
      <div class="bg-sombra-selva border-4 border-sangre-viva shadow-[8px_8px_0_rgba(246,0,123,0.4)] hover:shadow-[8px_8px_0_rgba(246,0,123,0.9)] hover:translate-y-[-4px] transition-all duration-300 p-8 flex flex-col relative">
        <div class="absolute -top-8 -left-4 font-title text-7xl text-sangre-viva drop-shadow-[3px_3px_0_#0c0c0c] select-none">01</div>
        <h3 class="font-title text-2xl text-fibra-natural uppercase tracking-wider mb-6 mt-4">The Core Foundation</h3>
        <ul class="text-fibra-natural/80 font-body space-y-5 flex-grow text-base md:text-lg">
          <li class="flex items-start gap-3">
            <span class="text-sangre-viva mt-1 select-none">▸</span>
            <span><strong class="text-white">The Tambo (Maloka):</strong> Rebuilding the sacred healing space aligned with Kamëntsá cosmovision around the sacred fire (Shinyak).</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-sangre-viva mt-1 select-none">▸</span>
            <span><strong class="text-white">Hospitality:</strong> Expanding the community kitchen and traditional guest accommodations to receive larger groups.</span>
          </li>
        </ul>
      </div>

      <div class="bg-sombra-selva border-4 border-padre-sol shadow-[8px_8px_0_rgba(243,156,18,0.2)] hover:shadow-[8px_8px_0_rgba(243,156,18,0.9)] hover:translate-y-[-4px] transition-all duration-300 p-8 flex flex-col relative mt-8 md:mt-0 opacity-80 hover:opacity-100">
        <div class="absolute -top-8 -left-4 font-title text-7xl text-padre-sol drop-shadow-[3px_3px_0_#0c0c0c] select-none">02</div>
        <h3 class="font-title text-2xl text-fibra-natural uppercase tracking-wider mb-6 mt-4">The Spaces of Life</h3>
        <ul class="text-fibra-natural/80 font-body space-y-5 flex-grow text-base md:text-lg">
          <li class="flex items-start gap-3">
            <span class="text-padre-sol mt-1 select-none">▸</span>
            <span><strong class="text-white">Aromatherapy:</strong> A dedicated room for healing via regional medicinal plants.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-padre-sol mt-1 select-none">▸</span>
            <span><strong class="text-white">Partería (Birth):</strong> A sacred space for the Mamitas to guide new life into the world.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-padre-sol mt-1 select-none">▸</span>
            <span><strong class="text-white">Private Healing:</strong> Isolated spaces for intensive energetic therapies.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-padre-sol mt-1 select-none">▸</span>
            <span><strong class="text-white">Women's Space:</strong> A respectful sanctuary dedicated to honoring the moon cycle.</span>
          </li>
        </ul>
      </div>

      <div class="bg-sombra-selva border-4 border-agua-pura shadow-[8px_8px_0_rgba(0,210,211,0.2)] hover:shadow-[8px_8px_0_rgba(0,210,211,0.9)] hover:translate-y-[-4px] transition-all duration-300 p-8 flex flex-col relative mt-8 md:mt-0 opacity-70 hover:opacity-100">
        <div class="absolute -top-8 -left-4 font-title text-7xl text-agua-pura drop-shadow-[3px_3px_0_#0c0c0c] select-none">03</div>
        <h3 class="font-title text-2xl text-fibra-natural uppercase tracking-wider mb-6 mt-4">Ancestral Pathways</h3>
        <ul class="text-fibra-natural/80 font-body space-y-5 flex-grow text-base md:text-lg">
          <li class="flex items-start gap-3">
            <span class="text-agua-pura mt-1 select-none">▸</span>
            <span><strong class="text-white">Living Botanical Garden:</strong> Constructing physical walking pathways through our preserved land.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-agua-pura mt-1 select-none">▸</span>
            <span><strong class="text-white">Educational Flora:</strong> An active map of local Amazonian and Andean medicinal plants to preserve our ecosystem's knowledge.</span>
          </li>
        </ul>
      </div>

    </div>
  </div>
</section>
