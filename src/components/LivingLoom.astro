---
// This component requires the lang prop to handle translations
import { t, type Language } from '../i18n/utils';
import { loomProducts } from '../data/loomProducts';
import LoomProductCard from './LoomProductCard.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="loom" class="bg-[#0c0c0c] py-32 px-[5%] md:px-[10%] relative border-t border-fibra-natural/10 overflow-hidden faja-divider">
  <!-- TODO: Finalize Living Loom section spacing and responsive breakpoints -->
  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
    
    <!-- TODO: Left side - conceptual textile frame content/art direction -->
    <div class="lg:col-span-5 relative group order-last lg:order-first">
      <!-- Gold Padre Sol solid offset background panel -->
      <div class="absolute inset-0 bg-padre-sol translate-x-3 translate-y-3 -z-10 transition-transform group-hover:translate-x-2 group-hover:translate-y-2 duration-300"></div>
      
      <div class="border-4 border-[#222] bg-[#111] aspect-square relative overflow-hidden flex items-center justify-center p-8 select-none">
        <!-- Structural Loom Line Simulation (Pure CSS Accents) -->
        <div class="absolute inset-0 flex justify-between px-8 opacity-20 pointer-events-none" aria-hidden="true">
          {[...Array(10)].map(() => (
            <div class="w-[1px] h-full bg-gradient-to-b from-transparent via-fibra-natural to-transparent"></div>
          ))}
        </div>
        
        <!-- Center Motif Label -->
        <div class="relative text-center z-10 space-y-3">
          <span class="font-title text-xs text-padre-sol tracking-widest uppercase block">
            Kamëntsá Katsa • Këshwá
          </span>
          <p class="font-title text-fibra-natural text-lg tracking-wider uppercase max-w-xs mx-auto leading-relaxed">
            Tejiendo la historia del territorio
          </p>
        </div>
      </div>
    </div>

    <!-- TODO: Right side - editorial statement and CTA copy review -->
    <div class="lg:col-span-7 space-y-8">
      <div class="space-y-2">
        <span class="font-title text-sm text-sangre-viva tracking-widest uppercase block">
          {t(lang, 'nav.loom')}
        </span>
        <h2 class="font-title text-4xl md:text-5xl text-fibra-natural uppercase tracking-wide">
          {t(lang, 'loom.title')}
        </h2>
      </div>

      <!-- Left-bordered high impact editorial block for the core quote -->
      <div class="relative pl-6 md:pl-8 border-l-2 border-padre-sol py-2">
        <p class="font-body text-xl md:text-2xl text-fibra-natural/95 italic leading-relaxed tracking-wide">
          {t(lang, 'loom.intro')}
        </p>
      </div>

      <!-- Action Navigation Button -->
      <div class="pt-4">
        <a 
          href="#shop" 
          class="inline-block px-8 py-4 border border-fibra-natural/30 text-fibra-natural font-title text-sm tracking-widest uppercase hover:bg-fibra-natural hover:text-[#0c0c0c] transition-all duration-300"
        >
          {t(lang, 'nav.artisanShop')}
        </a>
      </div>
    </div>

  </div>

  {/* TODO: Product cards grid temporarily disabled */}
  {/*
  <div class="max-w-6xl mx-auto mt-16 md:mt-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 items-stretch">
      {loomProducts.map((craft) => (
        <LoomProductCard craft={craft} lang={lang} />
      ))}
    </div>
  </div>
  */}
</section>
