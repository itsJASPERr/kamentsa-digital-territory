---
// Section 3: The Family & Jasper's Testimonial
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="family" class="bg-sombra-selva py-24 px-[5%] md:px-[10%] relative faja-divider">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
    
    <div class="relative w-full aspect-square md:aspect-[4/5] max-w-md mx-auto md:mx-0">
      <div class="absolute inset-0 border-4 border-tierra-madre bg-tierra-madre shadow-[12px_12px_0px_#f39c12] z-10 hover:translate-x-[-4px] hover:translate-y-[-4px] hover:shadow-[16px_16px_0px_#00d2d3] transition-all duration-500">
        <img 
          src="https://picsum.photos/800/800?random=4" 
          alt="The Muchavisoy Family" 
          class="w-full h-full object-cover filter contrast-105"
        />
        <div class="absolute top-0 left-0 w-8 h-8 bg-sangre-viva"></div>
      </div>
      
      <div class="absolute -bottom-6 -right-6 w-full h-full border-4 border-padre-sol z-0"></div>
    </div>

    <div class="flex flex-col justify-center py-4">
      
      <h2 class="font-title text-4xl sm:text-5xl text-padre-sol uppercase tracking-wider mb-6">
        {t(lang, 'family.title')}
      </h2>
      
      <p class="text-fibra-natural/90 font-body text-lg leading-relaxed mb-10">
        {t(lang, 'family.intro')}
      </p>

      <blockquote class="relative border-l-4 border-sangre-viva pl-6 md:pl-8 py-2 bg-tierra-madre/30 p-6 shadow-[4px_4px_0px_#111]">
        <span class="absolute -top-4 -left-3 font-title text-6xl text-sangre-viva/40 select-none">"</span>
        
        <h3 class="font-title text-xl text-agua-pura uppercase mb-3 tracking-wide">{t(lang, 'family.jasperTitle')}</h3>
        
        <p class="text-fibra-natural/80 font-body text-base italic leading-relaxed">
          {t(lang, 'family.jasperQuote')}
        </p>
      </blockquote>

    </div>

  </div>
</section>
