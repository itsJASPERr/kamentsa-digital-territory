---
interface Props {
  currentLang: 'en' | 'es';
  currentPath: string;
}

const { currentLang, currentPath } = Astro.props;

function getAlternateLanguageUrl(path: string, fromLang: string, toLang: string): string {
  const normalizedPath = path.replace(/\/+$|^\/$/g, '');

  if (!normalizedPath || normalizedPath === `/${fromLang}`) {
    return `/${toLang}/`;
  }

  if (normalizedPath.startsWith(`/${fromLang}/`)) {
    return normalizedPath.replace(`/${fromLang}/`, `/${toLang}/`);
  }

  return `/${toLang}${normalizedPath}`;
}

const alternateLang = currentLang === 'en' ? 'es' : 'en';
const alternateLabel = alternateLang === 'en' ? 'English' : 'Español';
const alternateUrl = getAlternateLanguageUrl(currentPath, currentLang, alternateLang);
---

<div class="language-switcher">
  <a href={alternateUrl} class="language-toggle" title={`Switch to ${alternateLabel}`}>
    {alternateLabel}
  </a>
</div>

<style>
  .language-switcher {
    display: inline-flex;
    align-items: center;
  }

  .language-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    background-color: #f6007b;
    color: #f5eee5;
    font-size: 0.75rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 2px solid #f39c12;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 2px 2px 0 #f39c12;
  }

  .language-toggle:hover {
    background-color: #00d2d3;
    color: #160a08;
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 #f6007b;
  }
</style>
