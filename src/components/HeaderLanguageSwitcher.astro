---
import { getAlternateLanguageUrl, t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
  currentPath: string;
  variant: 'desktop' | 'mobile';
}

const { lang, currentPath, variant } = Astro.props;

const desktopLinkClass =
  'font-title text-sm transition-colors';
const mobileLinkClass =
  'font-title text-lg transition-colors';

function getLinkClass(targetLang: Language) {
  const isActive = lang === targetLang;

  if (variant === 'desktop') {
    return isActive
      ? `${desktopLinkClass} text-white border-b-2 border-padre-sol pb-1`
      : `${desktopLinkClass} text-fibra-natural/50 hover:text-white`;
  }

  return isActive
    ? `${mobileLinkClass} text-white border-b-2 border-padre-sol pb-1`
    : `${mobileLinkClass} text-fibra-natural/50 hover:text-white`;
}
---

{variant === 'desktop' ? (
  <div class="flex items-center gap-2 border-l-2 border-fibra-natural/20 pl-6 ml-2">
    <a href={getAlternateLanguageUrl(currentPath, 'es')} class={getLinkClass('es')}>ES</a>
    <span class="text-fibra-natural/20">|</span>
    <a href={getAlternateLanguageUrl(currentPath, 'en')} class={getLinkClass('en')}>EN</a>
  </div>
) : (
  <div class="pb-12 pt-8 flex flex-col items-center gap-6 border-t-2 border-sombra-selva bg-[#0c0c0c]/30">
    <span class="font-body text-xs text-fibra-natural/50 uppercase tracking-widest">{t(lang, 'nav.language')}</span>
    <div class="flex items-center gap-4">
      <a href={getAlternateLanguageUrl(currentPath, 'es')} class={getLinkClass('es')}>ES</a>
      <span class="text-fibra-natural/20">|</span>
      <a href={getAlternateLanguageUrl(currentPath, 'en')} class={getLinkClass('en')}>EN</a>
    </div>
  </div>
)}