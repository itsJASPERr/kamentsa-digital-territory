---
// Main Header and Full-Screen Mobile Menu
import { t, type Language } from '../i18n/utils';
import HeaderLanguageSwitcher from './HeaderLanguageSwitcher.astro';
interface Props {
  lang: Language;
  currentPath: string;
}
const { lang, currentPath } = Astro.props;

---

<header class="fixed top-0 w-full z-40 bg-[#0c0c0c]/95 backdrop-blur-sm border-b-4 border-sangre-viva transition-all duration-300">
  <div class="max-w-7xl mx-auto px-[5%] md:px-[10%] h-20 flex items-center justify-between">
    
    <!-- <a href="/" class="font-title text-2xl text-fibra-natural uppercase tracking-widest hover:text-agua-pura transition-colors z-50">
      Kabunga
    </a> -->

     <h1 class="font-title text-3xl text-padre-sol uppercase tracking-wider drop-shadow-[2px_2px_0_#f6007b]">
      <button
        type="button"
        onclick="window.scrollTo({ top: 0, behavior: 'smooth' }); history.replaceState(null, '', window.location.pathname + window.location.search);"
        class="block text-left"
      >
        Kamëntsá
      </button>
    </h1>

    <nav class="hidden md:flex items-center gap-8">
      <a href="#vision" class="font-body text-sm text-fibra-natural uppercase tracking-widest hover:text-padre-sol transition-colors">{t(lang, 'nav.vision')}</a>
      <a href="#blueprint" class="font-body text-sm text-fibra-natural uppercase tracking-widest hover:text-padre-sol transition-colors">{t(lang, 'nav.stages')}</a>
      <a href="#loom" class="font-body text-sm text-fibra-natural uppercase tracking-widest hover:text-padre-sol transition-colors">{t(lang, 'nav.loom')}</a>
      
      <HeaderLanguageSwitcher lang={lang} currentPath={currentPath} variant="desktop" />

      <a href="#altar" class="ml-4 bg-transparent text-sangre-viva border-2 border-sangre-viva px-6 py-2 font-title uppercase text-sm hover:bg-sangre-viva hover:text-fibra-natural hover:shadow-[4px_4px_0_#00d2d3] transition-all duration-300">
        {t(lang, 'nav.support')}
      </a>
    </nav>

    <button 
      id="mobile-menu-open" 
      class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 z-50 group"
      aria-label="Open Menu"
    >
      <span class="w-8 h-1 bg-fibra-natural group-hover:bg-padre-sol transition-colors"></span>
      <span class="w-8 h-1 bg-fibra-natural group-hover:bg-padre-sol transition-colors"></span>
      <span class="w-8 h-1 bg-fibra-natural group-hover:bg-padre-sol transition-colors"></span>
    </button>

  </div>
</header>

<div 
  id="mobile-menu-overlay" 
  class="fixed inset-0 z-50 bg-tierra-madre flex flex-col transform translate-x-full transition-transform duration-500 ease-in-out md:hidden overflow-hidden border-l-8 border-padre-sol"
>
  <div class="h-20 px-[5%] flex items-center justify-between border-b-2 border-sombra-selva">
    <span class="font-title text-2xl text-agua-pura uppercase tracking-widest">
      {t(lang, 'nav.menu')}
    </span>
    <button 
      id="mobile-menu-close" 
      class="w-10 h-10 flex items-center justify-center z-50"
      aria-label="Close Menu"
    >
      <div class="relative w-8 h-8">
        <span class="absolute top-1/2 left-0 w-8 h-1 bg-sangre-viva rotate-45 transform -translate-y-1/2"></span>
        <span class="absolute top-1/2 left-0 w-8 h-1 bg-sangre-viva -rotate-45 transform -translate-y-1/2"></span>
      </div>
    </button>
  </div>

  <nav class="flex flex-col items-center justify-center flex-grow gap-8 px-[5%]">
    <a href="#vision" class="mobile-link font-title text-4xl text-fibra-natural uppercase tracking-wider hover:text-padre-sol transition-colors">{t(lang, 'nav.vision')}</a>
    <a href="#family" class="mobile-link font-title text-4xl text-fibra-natural uppercase tracking-wider hover:text-padre-sol transition-colors">{t(lang, 'nav.guardians')}</a>
    <a href="#blueprint" class="mobile-link font-title text-4xl text-fibra-natural uppercase tracking-wider hover:text-padre-sol transition-colors">{t(lang, 'nav.stages')}</a>
    <a href="#loom" class="mobile-link font-title text-4xl text-fibra-natural uppercase tracking-wider hover:text-padre-sol transition-colors">{t(lang, 'nav.loom')}</a>
    
    <a href="#altar" class="mobile-link mt-8 bg-padre-sol text-tierra-madre border-2 border-padre-sol px-10 py-4 font-title text-xl uppercase shadow-[6px_6px_0_#f6007b] active:translate-x-[2px] active:translate-y-[2px] active:shadow-[4px_4px_0_#f6007b] transition-all">
      {t(lang, 'nav.offerSupport')}
    </a>
  </nav>

  <HeaderLanguageSwitcher lang={lang} currentPath={currentPath} variant="mobile" />
</div>

<script>
  // Mobile Menu Logic
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtn = document.getElementById('mobile-menu-close');
  const menuOverlay = document.getElementById('mobile-menu-overlay');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const body = document.body;

  // Open Menu
  openBtn?.addEventListener('click', () => {
    menuOverlay?.classList.remove('translate-x-full');
    menuOverlay?.classList.add('translate-x-0');
    body.style.overflow = 'hidden'; // Prevent background scrolling
  });

  // Close Menu Function
  const closeMenu = () => {
    menuOverlay?.classList.remove('translate-x-0');
    menuOverlay?.classList.add('translate-x-full');
    body.style.overflow = ''; // Restore background scrolling
  };

  // Attach close event to the X button
  closeBtn?.addEventListener('click', closeMenu);

  // Close menu when a link inside it is clicked
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
