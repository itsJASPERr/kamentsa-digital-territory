---
import { t, type Language } from '../i18n/utils';
import DonationProgress from './DonationProgress.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
// Section 6: The Altar of Offerings (Fundraising Hub)
// Integrate this at the top of the section for maximum impact.
---

<section id="altar" class="bg-[#111] py-24 px-[5%] md:px-[10%] relative border-t-8 border-padre-sol">
  <div class="max-w-4xl mx-auto">

    <DonationProgress
      title={t(lang, 'altar.progress')}
      progressLabel="35%"
      footerText={t(lang, 'altar.fundingStatus')}
      wrapperClass="mb-16 p-8"
      titleClass="font-title text-2xl text-agua-pura uppercase tracking-wider mb-6 text-center"
      footerClass="text-center text-fibra-natural/60 text-sm mt-4 font-body uppercase tracking-widest"
    />

    <div class="text-center">
      <h2 class="font-title text-4xl sm:text-5xl text-agua-pura uppercase tracking-wider mb-8">
        {t(lang, 'altar.title')}
      </h2>
      
      <p class="text-fibra-natural/80 font-body text-lg md:text-xl leading-relaxed mb-12">
        {t(lang, 'altar.intro')}
      </p>

      <div class="grid md:grid-cols-3 gap-6 mb-16">
        <div class="border-2 border-sangre-viva p-6 bg-tierra-madre/20">
          <h4 class="text-sangre-viva font-title text-lg mb-2">{t(lang, 'altar.tier1Title')}</h4>
          <p class="text-fibra-natural/70 text-sm">{t(lang, 'altar.tier1Desc')}</p>
        </div>
        <div class="border-2 border-padre-sol p-6 bg-tierra-madre/20">
          <h4 class="text-padre-sol font-title text-lg mb-2">{t(lang, 'altar.tier2Title')}</h4>
          <p class="text-fibra-natural/70 text-sm">{t(lang, 'altar.tier2Desc')}</p>
        </div>
        <div class="border-2 border-agua-pura p-6 bg-tierra-madre/20">
          <h4 class="text-agua-pura font-title text-lg mb-2">{t(lang, 'altar.tier3Title')}</h4>
          <p class="text-fibra-natural/70 text-sm">{t(lang, 'altar.tier3Desc')}</p>
        </div>
      </div>

      <div class="bg-sombra-selva p-10 shadow-[10px_10px_0_#f6007b]">
        <p class="font-title text-2xl text-fibra-natural uppercase mb-8">{t(lang, 'altar.cta')}</p>
        
        <div class="min-h-[150px] flex items-center justify-center">
          <button
            id="altar-donate-btn"
            type="button"
            class="bg-padre-sol text-tierra-madre font-title text-xl uppercase px-10 py-4 border-2 border-padre-sol shadow-[6px_6px_0_#f6007b] hover:bg-sangre-viva hover:text-fibra-natural hover:border-sangre-viva hover:shadow-[6px_6px_0_#00d2d3] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all duration-300 select-none cursor-pointer"
          >
            {t(lang, 'nav.donateNow')}
          </button>
        </div>
      </div>
    </div>

  </div>
</section>
 