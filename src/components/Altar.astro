---
// This component requires the lang prop to handle translations
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="altar" class="bg-[#111] py-32 px-[5%] md:px-[10%] relative border-t border-fibra-natural/10">
  <div class="max-w-5xl mx-auto space-y-16">
    
    <!-- HEADER -->
    <div class="text-center max-w-3xl mx-auto space-y-6">
      <span class="font-title text-sm text-agua-pura tracking-widest uppercase block">
        {t(lang, 'altar.progress')}
      </span>
      <h2 class="font-title text-4xl md:text-5xl text-fibra-natural uppercase tracking-wide">
        {t(lang, 'altar.title')}
      </h2>
      <p class="font-body text-fibra-natural/80 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto">
        {t(lang, 'altar.intro')}
      </p>
    </div>

    <!-- CROWDFUNDING TRACKER -->
    <div class="bg-[#111] p-8 border border-fibra-natural/10 space-y-4 max-w-3xl mx-auto">
      <div class="flex justify-between items-end font-title text-sm uppercase tracking-wider">
        <span class="text-fibra-natural/60">{t(lang, 'altar.progress')}</span>
        <span class="text-padre-sol font-bold">{t(lang, 'altar.fundingStatus')}</span>
      </div>
      <!-- Progress Bar Container -->
      <div class="w-full bg-[#222] h-3 relative overflow-hidden">
        <!-- 35% Progress Indicator -->
        <div class="absolute top-0 left-0 bottom-0 bg-padre-sol w-[35%] transition-all duration-1000 ease-out"></div>
      </div>
    </div>

    <!-- CONTRIBUTION TIERS GRID -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pt-6">
      
      <!-- Tier 1 -->
      <div class="border border-fibra-natural/10 p-6 flex flex-col justify-between space-y-8 hover:border-agua-pura/30 transition-colors duration-300 bg-[#111]/20">
        <div class="space-y-3">
          <h3 class="font-title text-xl text-agua-pura uppercase tracking-wider">
            {t(lang, 'altar.tier1Title')}
          </h3>
          <p class="font-body text-fibra-natural/70 text-base leading-relaxed">
            {t(lang, 'altar.tier1Desc')}
          </p>
        </div>
      </div>

      <!-- Tier 2 -->
      <div class="border border-fibra-natural/10 p-6 flex flex-col justify-between space-y-8 hover:border-sangre-viva/30 transition-colors duration-300 bg-[#111]/20">
        <div class="space-y-3">
          <h3 class="font-title text-xl text-sangre-viva uppercase tracking-wider">
            {t(lang, 'altar.tier2Title')}
          </h3>
          <p class="font-body text-fibra-natural/70 text-base leading-relaxed">
            {t(lang, 'altar.tier2Desc')}
          </p>
        </div>
      </div>

      <!-- Tier 3 -->
      <div class="border border-fibra-natural/10 p-6 flex flex-col justify-between space-y-8 hover:border-padre-sol/30 transition-colors duration-300 bg-[#111]/20">
        <div class="space-y-3">
          <h3 class="font-title text-xl text-padre-sol uppercase tracking-wider">
            {t(lang, 'altar.tier3Title')}
          </h3>
          <p class="font-body text-fibra-natural/70 text-base leading-relaxed">
            {t(lang, 'altar.tier3Desc')}
          </p>
        </div>
      </div>

    </div>

    <!-- ACTION CALL -->
    <div class="text-center pt-8">
      <h4 class="font-title text-lg text-fibra-natural uppercase tracking-widest mb-6">
        {t(lang, 'altar.cta')}
      </h4>
      <!-- Trigger button targetting your global project modal execution hooks -->
      <button 
        id="altar-donate-btn"
        data-open-modal
        class="px-12 py-5 bg-sangre-viva text-fibra-natural font-title text-sm tracking-widest uppercase hover:bg-red-700 transition-all duration-300 shadow-xl cursor-pointer"
      >
        {t(lang, 'nav.donateNow')}
      </button>
    </div>

  </div>
</section>
